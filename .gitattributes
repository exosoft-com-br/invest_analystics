* text=auto eol=lf
*.{cmd,[cC][mM][dD]} text eol=crlf
*.{bat,[bB][aA][tT]} text eol=crlf

# Source code
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf

# Ensure UTF-8 encoding for TypeScript/JavaScript files
*.ts text working-tree-encoding=UTF-8
*.tsx text working-tree-encoding=UTF-8
*.js text working-tree-encoding=UTF-8
*.jsx text working-tree-encoding=UTF-8
